// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// NextAuth Required Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  
  // Custom Role Field
  role          Role      @default(CORP)
  phone         String?
  whatsapp      String?
  state         String?
  agentVerified Boolean   @default(false)
  isBanned      Boolean   @default(false)
  batch         String?   // For Corp members e.g. "Batch A 2026"

  // PPA Location for Corp Members
  ppaState      String?
  ppaLga        String?
  ppaLatitude   Float?
  ppaLongitude  Float?
  
  // Agent Application status
  agentRejected   Boolean   @default(false)
  rejectionReason String?   @db.Text
  
  // Premium Subscription
  isPremium        Boolean   @default(false)
  premiumPlan      String?   // "CORP_PREMIUM" | "AGENT_PREMIUM"
  premiumSince     DateTime?
  premiumExpiry    DateTime? // monthly renewal date

  // Relations
  accounts         Account[]
  sessions         Session[]
  properties       Property[] // Properties hosted by this user (if AGENT)
  bookings         Booking[]  // Bookings made by this user (if CORP)
  saved            SavedProperty[]
  reviews          Review[]   // Reviews left by this user (if CORP)
  viewings         Viewing[]  // Viewings scheduled by this user (if CORP)
  sentMessages     Message[]  @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  notifications    Notification[]
  artisans         Artisan[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom Application Models
enum Role {
  CORP
  AGENT
  ADMIN
}

enum PropertyStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

model Property {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  location    String
  state       String
  lga         String?
  latitude    Float?
  longitude   Float?
  price       Float
  bedrooms    Int            @default(1)
  bathrooms   Int            @default(1)
  amenities   String[]
  images      String[]
  status      PropertyStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  views       Int            @default(0)
  inquiries   Int            @default(0)

  isBoosted   Boolean  @default(false)
  agentId     String
  agent       User           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  bookings    Booking[]
  savedBy     SavedProperty[]
  reviews     Review[]
  viewings    Viewing[]
}

enum BookingStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
}

enum FeeStatus {
  UNPAID
  PAID
  REFUNDED
}

model Booking {
  id           String        @id @default(cuid())
  propertyId   String
  corpMemberId String
  date         DateTime
  time         String
  amount       Float         @default(0)
  status       BookingStatus @default(PENDING)
  feeStatus    FeeStatus     @default(UNPAID)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  corpMember   User          @relation(fields: [corpMemberId], references: [id], onDelete: Cascade)
}

model SavedProperty {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model Review {
  id           String   @id @default(cuid())
  rating       Int
  comment      String   @db.Text
  reply        String?  @db.Text
  propertyId   String
  corpMemberId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  corpMember   User     @relation(fields: [corpMemberId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(cuid())
  content    String   @db.Text
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())
  read       Boolean  @default(false)

  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

enum ViewingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Viewing {
  id           String        @id @default(cuid())
  propertyId   String
  corpMemberId String
  date         DateTime
  time         String
  status       ViewingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  corpMember   User          @relation(fields: [corpMemberId], references: [id], onDelete: Cascade)
}

model Artisan {
  id        String   @id @default(cuid())
  name      String
  trade     String   // Plumber, Electrician, Carpenter, Painter, AC Technician, Cleaner
  state     String
  lga       String
  phone     String
  rating    Float    @default(5.0)
  verified  Boolean  @default(false)
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum NotificationType {
  NEW_BOOKING
  BOOKING_STATUS_CHANGE
  NEW_MESSAGE
  NEW_REVIEW
  VIEWING_UPDATE
  AGENT_VERIFIED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}
